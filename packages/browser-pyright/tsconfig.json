{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "./out",
        "lib": [
            "es2023",
            "WebWorker",
            "ScriptHost"
        ],
        "types": [
            // not atually targeting node but pyright was written for node so we polyfill what we need in the webpack config
            "@types/node",
            "@core-js/types/pure"
        ],
        "paths": {
            "pyright-internal/*": [
                "../pyright-internal/src/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "out"
    ]
}
