{
    "name": "basedpyright",
    "displayName": "basedpyright",
    "description": "a fork of pyright with various type checking improvements, pylance features and more.",
    "version": "1.1.411",
    "license": "MIT",
    "author": {
        "name": "detachhead"
    },
    "engines": {
        "node": ">=14.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/detachhead/basedpyright",
        "directory": "packages/pyright"
    },
    "scripts": {
        "build": "rspack build -c rspack.config.js --mode production",
        "clean": "shx rm -rf ./dist ./out LICENSE.txt",
        "prepack": "npm run clean && shx cp ../../LICENSE.txt . && npm run build",
        "webpack": "rspack build -c rspack.config.js --mode development"
    },
    "optionalDependencies": {
        "fsevents": "~2.3.3"
    },
    "devDependencies": {
        "@core-js/types": "^4.0.0-alpha.1",
        "@rspack/cli": "^2.0.5",
        "@rspack/core": "^2.0.5",
        "@types/is-ci": "^3.0.4",
        "@types/node": "^25.9.2",
        "copy-webpack-plugin": "^14.0.0",
        "esbuild-loader": "^4.5.0",
        "shx": "^0.4.0",
        "ts-loader": "^9.5.4",
        "typescript": "~6.0.3"
    },
    "files": [
        "/dist",
        "LICENSE.txt"
    ],
    "main": "index.js",
    "bin": {
        "basedpyright": "index.js",
        "basedpyright-langserver": "langserver.index.js",
        "pyright": "index.js",
        "pyright-langserver": "langserver.index.js"
    },
    "overrides": {
        "tar": "7.5.11"
    }
}
